---
import {
  ArrowDown,
  ArrowUpRight,
  CheckCircle2,
  Cloud,
  Code2,
  Github,
  MapPin,
  ServerCog,
  Terminal,
} from 'lucide-astro';

const technologies = [
  'Java',
  'Spring Boot',
  'Azure',
  'Docker',
  'CI/CD',
];
---

<section
  id="top"
  class="relative isolate flex min-h-screen items-center overflow-hidden pt-28"
>
  <div
    class="grid-background pointer-events-none absolute inset-0 -z-20"
    aria-hidden="true"
  >
  </div>

  <div
    class="pointer-events-none absolute left-1/2 top-20 -z-10 size-[34rem] -translate-x-1/2 rounded-full bg-brand-400/10 blur-[120px]"
    aria-hidden="true"
  >
  </div>

  <div class="container-page py-20 lg:py-28">
    <div class="grid items-center gap-16 lg:grid-cols-[1.18fr_0.82fr] lg:gap-12">
      <div>
        <div
          class="mb-7 inline-flex items-center gap-2 rounded-full border border-brand-400/20 bg-brand-400/5 px-4 py-2 text-sm font-medium text-brand-200"
        >
          <span class="relative flex size-2">
            <span
              class="absolute inline-flex size-full animate-ping rounded-full bg-emerald-400 opacity-60"
            >
            </span>
            <span class="relative inline-flex size-2 rounded-full bg-emerald-400">
            </span>
          </span>

          Building reliable software in the banking industry
        </div>

        <p
          class="mb-5 text-sm font-semibold uppercase tracking-[0.22em] text-brand-300"
        >
          Software Engineer · Java & DevOps
        </p>

        <h1
          class="max-w-4xl text-5xl font-bold leading-[1.02] tracking-[-0.045em] text-white sm:text-6xl lg:text-7xl xl:text-[5.4rem]"
        >
          I build backend systems and
          <span class="text-gradient">the infrastructure behind them.</span>
        </h1>

        <p
          class="mt-8 max-w-2xl text-lg leading-8 text-slate-400 sm:text-xl sm:leading-9"
        >
          I’m Łukasz, a software engineer focused on Java, cloud platforms,
          delivery automation and dependable distributed systems.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="#projects"
            class="group inline-flex min-h-13 items-center justify-center gap-2 rounded-2xl bg-white px-6 py-3.5 font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-slate-200 focus-visible:outline-2 focus-visible:outline-brand-400"
          >
            Explore my work
            <ArrowDown
              size={18}
              class="transition group-hover:translate-y-0.5"
              aria-hidden="true"
            />
          </a>

          <a
            href="https://github.com/Senegalion"
            target="_blank"
            rel="noreferrer"
            class="group inline-flex min-h-13 items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white/[0.03] px-6 py-3.5 font-semibold text-white transition hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.06] focus-visible:outline-2 focus-visible:outline-brand-400"
          >
            <Github size={18} aria-hidden="true" />
            View GitHub
            <ArrowUpRight
              size={17}
              class="text-slate-500 transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-white"
              aria-hidden="true"
            />
          </a>
        </div>

        <div
          class="mt-12 flex flex-col gap-4 text-sm text-slate-400 sm:flex-row sm:flex-wrap sm:gap-x-7"
        >
          <span class="inline-flex items-center gap-2">
            <MapPin size={17} class="text-brand-300" aria-hidden="true" />
            Łódź, Poland
          </span>

          <span class="inline-flex items-center gap-2">
            <CheckCircle2
              size={17}
              class="text-brand-300"
              aria-hidden="true"
            />
            Open to international opportunities
          </span>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-lg lg:mx-0 lg:ml-auto">
        <div
          class="absolute -inset-10 -z-10 rounded-full bg-brand-500/10 blur-3xl"
          aria-hidden="true"
        >
        </div>

        <div
          class="overflow-hidden rounded-[2rem] border border-white/10 bg-slate-950/75 shadow-2xl shadow-black/40 backdrop-blur"
        >
          <div
            class="flex items-center justify-between border-b border-white/10 px-5 py-4"
          >
            <div class="flex gap-2" aria-hidden="true">
              <span class="size-2.5 rounded-full bg-red-400/80"></span>
              <span class="size-2.5 rounded-full bg-amber-400/80"></span>
              <span class="size-2.5 rounded-full bg-emerald-400/80"></span>
            </div>

            <span class="font-mono text-xs text-slate-500">
              engineer.profile
            </span>

            <Terminal size={16} class="text-slate-600" aria-hidden="true" />
          </div>

          <div class="space-y-6 p-6 sm:p-8">
            <div>
              <p class="font-mono text-sm text-slate-500">
                <span class="text-brand-300">const</span>
                engineer =
              </p>

              <div
                class="mt-3 rounded-2xl border border-white/8 bg-white/[0.025] p-5 font-mono text-sm leading-7"
              >
                <p>
                  <span class="text-violet-300">name:</span>
                  <span class="text-emerald-300">'Łukasz Pelikan'</span>,
                </p>
                <p>
                  <span class="text-violet-300">role:</span>
                  <span class="text-emerald-300">'Software Engineer'</span>,
                </p>
                <p>
                  <span class="text-violet-300">focus:</span>
                  [
                </p>
                <p class="pl-5 text-emerald-300">
                  'Backend', 'Cloud', 'DevOps'
                </p>
                <p>],</p>
                <p>
                  <span class="text-violet-300">mindset:</span>
                  <span class="text-emerald-300">'keep shipping'</span>
                </p>
              </div>
            </div>

            <div class="grid grid-cols-3 gap-3">
              <div
                class="rounded-2xl border border-white/8 bg-white/[0.025] p-4"
              >
                <Code2
                  size={20}
                  class="mb-5 text-brand-300"
                  aria-hidden="true"
                />
                <p class="text-sm font-semibold text-white">Backend</p>
                <p class="mt-1 text-xs text-slate-500">Java & Spring</p>
              </div>

              <div
                class="rounded-2xl border border-white/8 bg-white/[0.025] p-4"
              >
                <Cloud
                  size={20}
                  class="mb-5 text-brand-300"
                  aria-hidden="true"
                />
                <p class="text-sm font-semibold text-white">Cloud</p>
                <p class="mt-1 text-xs text-slate-500">Azure & AWS</p>
              </div>

              <div
                class="rounded-2xl border border-white/8 bg-white/[0.025] p-4"
              >
                <ServerCog
                  size={20}
                  class="mb-5 text-brand-300"
                  aria-hidden="true"
                />
                <p class="text-sm font-semibold text-white">Delivery</p>
                <p class="mt-1 text-xs text-slate-500">CI/CD & Docker</p>
              </div>
            </div>

            <div class="flex flex-wrap gap-2">
              {
                technologies.map((technology) => (
                  <span class="rounded-full border border-white/8 bg-white/[0.025] px-3 py-1.5 text-xs font-medium text-slate-400">
                    {technology}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>