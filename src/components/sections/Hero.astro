---
import {
  ArrowDown,
  ArrowUpRight,
  CheckCircle2,
  Cloud,
  Code2,
  Github,
  MapPin,
  ServerCog,
  Terminal,
} from 'lucide-astro';

const technologies = [
  'Java',
  'Spring Boot',
  'Azure',
  'Docker',
  'CI/CD',
];
---

<section
  id="top"
  class="relative isolate flex min-h-screen max-w-full items-center overflow-hidden pt-28"
>
  <div
    class="grid-background pointer-events-none absolute inset-0 -z-20 max-w-full"
    aria-hidden="true"
  >
  </div>

  <div
    class="pointer-events-none absolute left-1/2 top-20 -z-10 h-[28rem] w-[28rem] max-w-[90vw] -translate-x-1/2 rounded-full bg-brand-400/10 blur-[120px] sm:h-[34rem] sm:w-[34rem]"
    aria-hidden="true"
  >
  </div>

  <div class="container-page max-w-full py-20 lg:py-28">
    <div
      class="grid min-w-0 max-w-full items-center gap-16 lg:grid-cols-[minmax(0,1.18fr)_minmax(0,0.82fr)] lg:gap-12"
    >
      <div class="min-w-0 max-w-full">
        <div
          class="mb-7 flex w-fit max-w-full items-center gap-2 rounded-3xl border border-brand-400/20 bg-brand-400/5 px-4 py-3 text-sm font-medium leading-6 text-brand-200"
        >
          <span class="relative flex size-2 shrink-0">
            <span
              class="absolute inline-flex size-full animate-ping rounded-full bg-emerald-400 opacity-60"
            >
            </span>

            <span
              class="relative inline-flex size-2 rounded-full bg-emerald-400"
            >
            </span>
          </span>

          <span class="min-w-0">
            Building reliable software in the banking industry
          </span>
        </div>

        <p
          class="mb-5 max-w-full text-sm font-semibold uppercase tracking-[0.22em] text-brand-300"
        >
          Software Engineer · Java & DevOps
        </p>

        <h1
          class="max-w-full break-words text-[clamp(3rem,13vw,5rem)] font-bold leading-[1.02] tracking-[-0.045em] text-white sm:text-6xl lg:text-7xl xl:text-[5.4rem]"
        >
          I build backend systems and{' '}
          <span class="text-gradient">
            the infrastructure behind them.
          </span>
        </h1>

        <p
          class="mt-8 max-w-2xl text-lg leading-8 text-slate-400 sm:text-xl sm:leading-9"
        >
          I’m Łukasz, a software engineer focused on Java, cloud platforms,
          delivery automation and dependable distributed systems.
        </p>

        <div class="mt-10 flex max-w-full flex-col gap-4 sm:flex-row">
          <a
            href="#projects"
            class="group inline-flex min-h-13 max-w-full items-center justify-center gap-2 rounded-2xl bg-white px-6 py-3.5 font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-slate-200 focus-visible:outline-2 focus-visible:outline-brand-400"
          >
            Explore my work

            <ArrowDown
              size={18}
              class="shrink-0 transition group-hover:translate-y-0.5"
              aria-hidden="true"
            />
          </a>

          <a
            href="https://github.com/Senegalion"
            target="_blank"
            rel="noreferrer"
            class="group inline-flex min-h-13 max-w-full items-center justify-center gap-2 rounded-2xl border border-white/10 bg-white/[0.03] px-6 py-3.5 font-semibold text-white transition hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.06] focus-visible:outline-2 focus-visible:outline-brand-400"
          >
            <Github size={18} class="shrink-0" aria-hidden="true" />

            View GitHub

            <ArrowUpRight
              size={17}
              class="shrink-0 text-slate-500 transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-white"
              aria-hidden="true"
            />
          </a>
        </div>

        <div
          class="mt-12 flex max-w-full flex-col gap-4 text-sm text-slate-400 sm:flex-row sm:flex-wrap sm:gap-x-7"
        >
          <span class="inline-flex min-w-0 items-center gap-2">
            <MapPin
              size={17}
              class="shrink-0 text-brand-300"
              aria-hidden="true"
            />

            Łódź, Poland
          </span>

          <span class="inline-flex min-w-0 items-center gap-2">
            <CheckCircle2
              size={17}
              class="shrink-0 text-brand-300"
              aria-hidden="true"
            />

            Open to international opportunities
          </span>
        </div>
      </div>

      <div
        class="relative mx-auto min-w-0 w-full max-w-lg lg:mx-0 lg:ml-auto"
      >
        <div
          class="absolute -inset-6 -z-10 rounded-full bg-brand-500/10 blur-3xl sm:-inset-10"
          aria-hidden="true"
        >
        </div>

        <div
          class="max-w-full overflow-hidden rounded-[2rem] border border-white/10 bg-slate-950/75 shadow-2xl shadow-black/40 backdrop-blur"
        >
          <div
            class="flex min-w-0 items-center justify-between gap-4 border-b border-white/10 px-5 py-4"
          >
            <div class="flex shrink-0 gap-2" aria-hidden="true">
              <span class="size-2.5 rounded-full bg-red-400/80"></span>
              <span class="size-2.5 rounded-full bg-amber-400/80"></span>
              <span class="size-2.5 rounded-full bg-emerald-400/80"></span>
            </div>

            <span class="min-w-0 truncate font-mono text-xs text-slate-500">
              engineer.profile
            </span>

            <Terminal
              size={16}
              class="shrink-0 text-slate-600"
              aria-hidden="true"
            />
          </div>

          <div class="min-w-0 space-y-6 p-5 sm:p-8">
            <div class="min-w-0">
              <p class="max-w-full font-mono text-sm text-slate-500">
                <span class="text-brand-300">const</span>{' '}
                engineer =
              </p>

              <div
                class="mt-3 min-w-0 max-w-full overflow-hidden rounded-2xl border border-white/8 bg-white/[0.025] p-4 font-mono text-xs leading-7 sm:p-5 sm:text-sm"
              >
                <p class="break-words">
                  <span class="text-violet-300">name:</span>{' '}
                  <span class="text-emerald-300">'Łukasz Pelikan'</span>,
                </p>

                <p class="break-words">
                  <span class="text-violet-300">role:</span>{' '}
                  <span class="text-emerald-300">'Software Engineer'</span>,
                </p>

                <p>
                  <span class="text-violet-300">focus:</span> [
                </p>

                <p class="break-words pl-4 text-emerald-300 sm:pl-5">
                  'Backend', 'Cloud', 'DevOps'
                </p>

                <p>],</p>

                <p class="break-words">
                  <span class="text-violet-300">mindset:</span>{' '}
                  <span class="text-emerald-300">'keep shipping'</span>
                </p>
              </div>
            </div>

            <div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-3">
              <div
                class="min-w-0 rounded-2xl border border-white/8 bg-white/[0.025] p-4"
              >
                <Code2
                  size={20}
                  class="mb-5 text-brand-300"
                  aria-hidden="true"
                />

                <p class="text-sm font-semibold text-white">
                  Backend
                </p>

                <p class="mt-1 text-xs text-slate-500">
                  Java & Spring
                </p>
              </div>

              <div
                class="min-w-0 rounded-2xl border border-white/8 bg-white/[0.025] p-4"
              >
                <Cloud
                  size={20}
                  class="mb-5 text-brand-300"
                  aria-hidden="true"
                />

                <p class="text-sm font-semibold text-white">
                  Cloud
                </p>

                <p class="mt-1 text-xs text-slate-500">
                  Azure & AWS
                </p>
              </div>

              <div
                class="min-w-0 rounded-2xl border border-white/8 bg-white/[0.025] p-4"
              >
                <ServerCog
                  size={20}
                  class="mb-5 text-brand-300"
                  aria-hidden="true"
                />

                <p class="text-sm font-semibold text-white">
                  Delivery
                </p>

                <p class="mt-1 text-xs text-slate-500">
                  CI/CD & Docker
                </p>
              </div>
            </div>

            <div class="flex min-w-0 max-w-full flex-wrap gap-2">
              {
                technologies.map((technology) => (
                  <span class="max-w-full rounded-full border border-white/8 bg-white/[0.025] px-3 py-1.5 text-xs font-medium text-slate-400">
                    {technology}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>