---
import {
  ArrowUpRight,
  Boxes,
  BrainCircuit,
  CloudCog,
  Code2,
  GraduationCap,
  ShieldCheck,
} from 'lucide-astro';

const areas = [
  {
    icon: Code2,
    title: 'Backend engineering',
    description:
      'Designing maintainable services and APIs with Java, Spring Boot, relational databases and automated tests.',
  },
  {
    icon: CloudCog,
    title: 'Cloud & delivery',
    description:
      'Building CI/CD pipelines, containerized environments and dependable deployment workflows across cloud platforms.',
  },
  {
    icon: Boxes,
    title: 'System architecture',
    description:
      'Exploring modular systems, messaging, distributed communication and pragmatic architectural decisions.',
  },
  {
    icon: ShieldCheck,
    title: 'Reliable software',
    description:
      'Focusing on observability, security, testing and operational stability rather than code that only works locally.',
  },
];

const facts = [
  {
    icon: GraduationCap,
    value: 'MSc',
    label: 'Applied Computer Science (Software Engineering and Machine Learning)',
  },
  {
    icon: GraduationCap,
    value: 'B.Eng',
    label: 'Computer Science',
  },
  {
    icon: BrainCircuit,
    value: 'Java',
    label: 'Primary engineering language',
  },
  {
    icon: CloudCog,
    value: 'Cloud',
    label: 'Azure and AWS experience',
  },
];
---

<section id="about" class="relative overflow-hidden py-28 sm:py-36">
  <div
    class="pointer-events-none absolute left-0 top-1/3 -z-10 size-96 rounded-full bg-brand-500/5 blur-[120px]"
    aria-hidden="true"
  >
  </div>

  <div class="container-page">
    <div class="grid gap-16 lg:grid-cols-[0.8fr_1.2fr] lg:gap-24">
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-300"
        >
          About me
        </p>

        <h2
          class="mt-5 text-4xl font-bold tracking-[-0.035em] text-white sm:text-5xl"
        >
          Engineering beyond writing code.
        </h2>

        <div class="mt-8 space-y-5 text-lg leading-8 text-slate-400">
          <p>
            I’m a software engineer working at the intersection of backend
            development, cloud infrastructure and DevOps.
          </p>

          <p>
            My core stack is Java and Spring Boot, but I’m equally interested in
            how software is tested, delivered, monitored and operated after it
            leaves a developer’s machine.
          </p>

          <p>
            I currently work in the banking industry, where reliability,
            security and disciplined engineering matter more than impressive
            demos.
          </p>
        </div>

        <a
          href="https://mail.google.com/mail/?view=cm&fs=1&to=lupelikan@gmail.com"
          target="_blank"
          rel="noreferrer"
          class="group mt-10 inline-flex items-center gap-2 font-semibold text-white transition hover:text-brand-200 focus-visible:rounded focus-visible:outline-2 focus-visible:outline-brand-400"
        >
          Let’s talk
          <ArrowUpRight
            size={18}
            class="transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
            aria-hidden="true"
          />
        </a>
      </div>

      <div>
        <div class="grid gap-4 sm:grid-cols-2">
          {
            areas.map(({ icon: Icon, title, description }) => (
              <article class="group rounded-[1.75rem] border border-white/8 bg-white/[0.025] p-6 transition duration-300 hover:-translate-y-1 hover:border-brand-400/20 hover:bg-white/[0.04] sm:p-7">
                <div class="grid size-11 place-items-center rounded-2xl border border-brand-400/15 bg-brand-400/8 text-brand-300 transition group-hover:border-brand-400/30 group-hover:bg-brand-400/12">
                  <Icon size={21} aria-hidden="true" />
                </div>

                <h3 class="mt-6 text-lg font-semibold text-white">
                  {title}
                </h3>

                <p class="mt-3 leading-7 text-slate-400">
                  {description}
                </p>
              </article>
            ))
          }
        </div>

        <div class="mt-5 grid gap-4 sm:grid-cols-3">
          {
            facts.map(({ icon: Icon, value, label }) => (
              <div class="rounded-2xl border border-white/8 bg-slate-950/50 p-5">
                <Icon
                  size={18}
                  class="text-brand-300"
                  aria-hidden="true"
                />

                <p class="mt-5 text-xl font-bold text-white">
                  {value}
                </p>

                <p class="mt-1 text-sm leading-6 text-slate-500">
                  {label}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>