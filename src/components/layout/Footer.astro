---
import { ArrowUp, Github, Linkedin, Mail, Phone } from 'lucide-astro';

const currentYear = new Date().getFullYear();
---

<footer
  id="contact"
  class="border-t border-white/5 bg-[#060a12] py-16"
>
  <div class="container-page">
    <div class="grid gap-12 lg:grid-cols-[1fr_auto] lg:items-end">
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-300"
        >
          Contact
        </p>

        <h2
          class="mt-5 max-w-3xl text-4xl font-bold tracking-[-0.035em] text-white sm:text-5xl"
        >
          Let’s build something worth shipping.
        </h2>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-400">
          I’m open to conversations about backend engineering, cloud
          infrastructure, DevOps and international software opportunities.
        </p>

        <a
          href="https://mail.google.com/mail/?view=cm&fs=1&to=lupelikan@gmail.com"
          target="_blank"
          rel="noreferrer"
          class="mt-8 inline-flex min-h-12 items-center justify-center gap-2 rounded-xl bg-white px-5 font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-slate-200 focus-visible:outline-2 focus-visible:outline-brand-400"
        >
          <Mail size={18} aria-hidden="true" />
          lupelikan@gmail.com
        </a>
        <a
          href="tel:+48506349098"
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl border border-white/10 bg-white/[0.03] px-5 font-semibold text-white transition hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.06] focus-visible:outline-2 focus-visible:outline-brand-400"
        >
          <Phone size={18} aria-hidden="true" />
          +48 506 349 098
        </a>
      </div>

      <div class="flex gap-3">
        <a
          href="https://github.com/Senegalion"
          target="_blank"
          rel="noreferrer"
          class="grid size-12 place-items-center rounded-xl border border-white/10 text-slate-400 transition hover:border-white/20 hover:bg-white/[0.04] hover:text-white"
          aria-label="GitHub profile"
        >
          <Github size={20} aria-hidden="true" />
        </a>

        <a
          href="https://www.linkedin.com/in/łukasz-pelikan"
          target="_blank"
          rel="noreferrer"
          class="grid size-12 place-items-center rounded-xl border border-white/10 text-slate-400 transition hover:border-white/20 hover:bg-white/[0.04] hover:text-white"
          aria-label="LinkedIn profile"
        >
          <Linkedin size={20} aria-hidden="true" />
        </a>

        <a
          href="#top"
          class="grid size-12 place-items-center rounded-xl border border-white/10 text-slate-400 transition hover:border-white/20 hover:bg-white/[0.04] hover:text-white"
          aria-label="Back to top"
        >
          <ArrowUp size={20} aria-hidden="true" />
        </a>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col gap-3 border-t border-white/5 pt-6 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {currentYear} Łukasz Pelikan.</p>
    </div>
  </div>
</footer>